# Card/set images: stored on disk (UPLOAD_DIR), not in DB. Persist across deploys (volume or bind mount).
# UPLOAD_DIR=uploads
# WebAuthn (passkeys): optional; rp_id and origin default from FRONTEND_URL
# WEBAUTHN_RP_ID=localhost
# WEBAUTHN_RP_NAME=Tritone Cards
# WEBAUTHN_ORIGIN=http://localhost:5175
