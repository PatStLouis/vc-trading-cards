BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8000/auth/callback
# Discord Bot (slash commands): create a Bot in the same Discord app, copy token and public key
# DISCORD_BOT_TOKEN=
# DISCORD_PUBLIC_KEY=
# Twitch OAuth (login + bind): create app at https://dev.twitch.tv/console/apps
# Both Discord and Twitch use the same callback URL: /auth/callback (provider is inferred from state).
# Twitch only accepts HTTPS redirect URIs; for local dev use an HTTPS tunnel (e.g. ngrok).
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
# Use same callback as Discord (e.g. https://your-app.ngrok-free.app/auth/callback)
# TWITCH_REDIRECT_URI=https://your-app.ngrok-free.app/auth/callback
# Admin: also support Twitch user IDs for /admin
# ADMIN_TWITCH_IDS=
# Optional: admin API key for server-to-server or script access (X-Admin-API-Key or Authorization: Bearer <key>)
# ADMIN_API_KEY=
SECRET_KEY=change-me-in-production
ACAPY_ADMIN_URL=http://localhost:8020
ACAPY_ADMIN_API_KEY=
INNKEEPER_ID=
INNKEEPER_KEY=
ADMIN_DISCORD_IDS=
# Comma-separated Discord user IDs; these users see the Admin button and can access /admin. Get your ID: Discord → Settings → Advanced → Developer Mode ON → right-click your avatar → Copy User ID.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tritone_cards
# Card/set images: stored on disk (UPLOAD_DIR), not in DB. Persist across deploys (volume or bind mount).
# UPLOAD_DIR=uploads
# WebAuthn (passkeys): optional; rp_id and origin default from FRONTEND_URL
# WEBAUTHN_RP_ID=localhost
# WEBAUTHN_RP_NAME=Tritone Cards
# WEBAUTHN_ORIGIN=http://localhost:5175
# Security: rate limiting (per IP). Enable with RATE_LIMIT_ENABLED=1
# RATE_LIMIT_ENABLED=0
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_WINDOW_SECONDS=60
