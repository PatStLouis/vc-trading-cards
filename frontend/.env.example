# Optional: backend API origin (only needed when frontend is served from a different host than the API).
# Leave unset or empty for same-origin (e.g. dev proxy or same domain in production).
# Example for production: https://api.yourproject.com
# VITE_API_URL=

# Optional: app icon/logo URL. Used in headers, nav, and QR code center. Fallback: /favicon.png
# Use absolute URL (https://...) or path (e.g. /logo.svg). For cross-origin, image must be CORS-enabled.
# VITE_APP_ICON_URL=
