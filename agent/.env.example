# ACA-Py agent env (optional – many settings are in argfile.yml)
# JWT secret for multitenant wallet tokens. Override when running the container.
# ACAPY_JWT_SECRET=your-256-bit-secret

# Innkeeper wallet key (substituted into argfile.yml at startup). Match backend INNKEEPER_KEY for admin tenant.
# INNKEEPER_WALLET_KEY=your-innkeeper-wallet-key

# Optional: use admin API key instead of insecure mode (then set ACAPY_ADMIN_API_KEY in backend .env)
# ACAPY_ADMIN_API_KEY=your-admin-key
